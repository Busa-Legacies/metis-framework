{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/file-guard.sh pre-check '$TOOL_INPUT' \"${CLAUDE_SESSION_ID:-unknown}\"",
            "statusMessage": "Checking for concurrent edits..."
          },
          {
            "type": "command",
            "command": "~/.local/bin/checkout-guard.sh '$TOOL_INPUT' \"${CLAUDE_SESSION_ID:-unknown}\"",
            "statusMessage": "Checking checkout protocol..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/file-guard.sh post-write '$TOOL_INPUT' \"${CLAUDE_SESSION_ID:-unknown}\""
          },
          {
            "type": "command",
            "command": "~/.local/bin/claude-format.sh",
            "statusMessage": "Formatting..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/file-guard.sh post-read '$TOOL_INPUT' \"${CLAUDE_SESSION_ID:-unknown}\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"PreCompact\", \"additionalContext\": \"MEMORY CHECKPOINT: This conversation is about to be compacted. Save any significant progress, decisions, task completions, or system-state changes to your Claude Code project memory dir (~/.claude/projects/<project>/memory/) and update MEMORY.md before compaction. If nothing significant happened, no action needed.\"}}'",
            "statusMessage": "Saving session memory..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/claude-post-compact.sh",
            "statusMessage": "Re-injecting session context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/claude-machine-identity.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hook-session-init.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hook-prompt-guard.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hook-plan-nudge.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hook-alerts.sh"
          }
        ]
      }
    ]
  }
}
