{
  "name": "metis-command",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "description": "Metis OS — multi-agent command cockpit for Claude, Codex, and OpenClaw lanes.",
  "author": "Anthony Abusa",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const root=p.join('node_modules','node-pty','prebuilds');try{for(const d of fs.readdirSync(root)){const f=p.join(root,d,'spawn-helper');if(fs.existsSync(f)){fs.chmodSync(f,0o755);console.log('chmod +x',f)}}}catch(e){}\"",
    "dev": "concurrently -n web,pty -c cyan,magenta \"next dev -p 3747\" \"tsx watch server/pty-server.ts\"",
    "dev:web": "next dev -p 3747",
    "dev:lan": "concurrently -n web,pty -c cyan,magenta \"next dev -p 3747 -H 0.0.0.0\" \"cross-env AW_PTY_HOST=0.0.0.0 tsx watch server/pty-server.ts\"",
    "dev:pty": "tsx watch server/pty-server.ts",
    "test": "tsx --test tests/*.test.ts",
    "build": "next build",
    "start": "concurrently -n web,pty -c cyan,magenta \"next start -p 3747\" \"tsx server/pty-server.ts\"",
    "start:prod": "concurrently -n web,pty -c cyan,magenta \"next start -p 3747 -H 127.0.0.1\" \"cross-env AW_PTY_HOST=127.0.0.1 tsx server/pty-server.ts\"",
    "app": "next build && electron .",
    "app:dev": "cross-env AW_NEXT_MODE=dev electron .",
    "app:dist": "next build && electron-builder --mac --arm64",
    "app:dist:dir": "next build && electron-builder --mac --arm64 --dir",
    "lint": "eslint",
    "smoke:browser": "node scripts/browser-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:ui": "playwright test --ui",
    "test:pty": "node --import tsx --test tests/pty-server-lifecycle.test.ts",
    "typecheck": "tsc --noEmit",
    "repackage:fast": "bash scripts/repackage-fast.sh"
  },
  "build": {
    "appId": "com.metis.command",
    "productName": "Metis Command",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "lib/**/*",
      "components/**/*",
      "app/**/*",
      ".next/**/*",
      "next.config.ts",
      "tsconfig.json",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": false,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.15.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.7",
    "node-pty": "^1.1.0",
    "openai": "^6.36.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
