# Required for the in-app assistant
OPENAI_API_KEY=sk-...

# Model used for the assistant. Falls back to AW_FALLBACK_MODEL on error.
AW_ASSISTANT_MODEL=gpt-5.5
AW_FALLBACK_MODEL=gpt-4o

# PTY sidecar
AW_PTY_PORT=3748

# Override CLI binaries (leave blank to use $PATH default)
# AW_CLAUDE_CMD=claude
# AW_CODEX_CMD=codex
# AW_GEMINI_CMD=gemini
