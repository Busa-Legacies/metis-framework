{
  "name": "dev-review",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const root=p.join('node_modules','node-pty','prebuilds');try{for(const d of fs.readdirSync(root)){const f=p.join(root,d,'spawn-helper');if(fs.existsSync(f)){fs.chmodSync(f,0o755);console.log('chmod +x',f)}}}catch(e){}\"",
    "dev": "concurrently -n web,pty -c cyan,magenta \"next dev -p 3760\" \"tsx watch server/pty-server.ts\"",
    "dev:web": "next dev -p 3760",
    "dev:pty": "tsx watch server/pty-server.ts",
    "test": "tsx --test tests/*.test.ts",
    "build": "next build",
    "start": "concurrently -n web,pty -c cyan,magenta \"next start -p 3760\" \"tsx server/pty-server.ts\"",
    "app": "next build && electron .",
    "app:dev": "cross-env AW_NEXT_MODE=dev electron .",
    "app:dist": "next build && electron-builder --mac --arm64",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.4",
    "node-pty": "^1.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^2.1.9",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.metis.devreview",
    "productName": "Dev Review",
    "files": [
      "electron/**",
      ".next/**",
      "server/**",
      "lib/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  }
}
