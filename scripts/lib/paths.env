# Canonical repo-root path — single source for shell scripts (Metis OS).
#
# Source this, then use $METIS_HOME:
#     . "$(dirname "$0")/lib/paths.env"
#     cd "$METIS_HOME"
#
# The default SELF-LOCATES from this file's own position (scripts/lib/paths.env),
# so it stays correct regardless of what the repo directory is named or where it
# is moved. This is what makes the Ant-openclaw-framework -> metis-os rename a
# zero-edit move: nothing hardcodes the directory name.
#
# Override by exporting METIS_HOME before invoking — the := only sets a default.
# Standalone Python uses lib/paths.py (mirrors this).

# Resolve THIS file's path across bash and zsh.
if [ -n "${BASH_SOURCE:-}" ]; then
  _metis_src="${BASH_SOURCE[0]}"
elif [ -n "${ZSH_VERSION:-}" ]; then
  _metis_src="${(%):-%x}"
else
  _metis_src="$0"
fi

# repo root = <this file>/../..  (scripts/lib/paths.env -> repo root)
: "${METIS_HOME:=$(cd "$(dirname "$_metis_src")/../.." && pwd)}"
export METIS_HOME
unset _metis_src
