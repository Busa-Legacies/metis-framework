# Canonical Tailscale IPs — single source for shell scripts.
# Source this (e.g. `. "$(dirname "$0")/lib/network.env"`) then use $JAY_IP / $JARRY_IP.
# Override by exporting JAY_IP / JARRY_IP before invoking — the := only sets a default.
# The dashboard package mirrors these via app/core/config.py; standalone Python via lib/network.py.
: "${JAY_IP:=<<MACHINE_1_TAILSCALE_IP>>}"     # primary machine
: "${JARRY_IP:=<<MACHINE_2_TAILSCALE_IP>>}"  # secondary machine
export JAY_IP JARRY_IP
